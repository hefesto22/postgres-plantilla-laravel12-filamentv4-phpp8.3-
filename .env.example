# ─────────────────────────────────────────────────────────────────
# APLICACIÓN
# ─────────────────────────────────────────────────────────────────
APP_NAME="Plantilla Olympo"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://plantilla-olympo.test
APP_TIMEZONE=America/Tegucigalpa

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_HN

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# Identificador único del proyecto — usado como prefijo de Redis,
# nombre de contenedores Docker y branding del panel admin.
APP_SLUG=plantilla_olympo
APP_BRAND_NAME="${APP_NAME}"

# ─────────────────────────────────────────────────────────────────
# LOGGING — stack JSON + Sentry para errores en producción
# ─────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=daily,sentry
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─────────────────────────────────────────────────────────────────
# BASE DE DATOS — PostgreSQL 16+ (estándar Grupo Olympo)
# ─────────────────────────────────────────────────────────────────
# Si reutilizas el contenedor Docker compartido del VPS, apunta a
# 127.0.0.1:5432 con el usuario y password del contenedor.
# Si levantas docker-compose.yml local, los valores por defecto coinciden.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=plantilla_olympo
DB_USERNAME=postgres
DB_PASSWORD=
DB_SCHEMA=public

# ─────────────────────────────────────────────────────────────────
# REDIS — cache, sesión, queue y locks distribuidos
# ─────────────────────────────────────────────────────────────────
# Cuando varios proyectos comparten una instancia Redis, asigna un
# REDIS_DB único por proyecto (db0..db15) y usa REDIS_PREFIX para
# aislar las keys. Ver §19.4 del documento de instrucciones.
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2
REDIS_PREFIX="${APP_SLUG}_"

# ─────────────────────────────────────────────────────────────────
# CACHE / SESSION / QUEUE — todos sobre Redis en producción
# ─────────────────────────────────────────────────────────────────
CACHE_STORE=redis
CACHE_PREFIX="${APP_SLUG}_cache"

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

QUEUE_CONNECTION=redis
HORIZON_DOMAIN=
HORIZON_PATH=horizon
HORIZON_PREFIX="${APP_SLUG}_horizon:"

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ─────────────────────────────────────────────────────────────────
# CORREO
# ─────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@grupoolympo.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─────────────────────────────────────────────────────────────────
# ALMACENAMIENTO S3-COMPATIBLE — para backups y archivos grandes
# ─────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─────────────────────────────────────────────────────────────────
# OBSERVABILIDAD — Sentry
# ─────────────────────────────────────────────────────────────────
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
SENTRY_SEND_DEFAULT_PII=false

# ─────────────────────────────────────────────────────────────────
# BROWSERSHOT — generación de PDFs vía Chromium headless
# ─────────────────────────────────────────────────────────────────
# En Herd/macOS local: deja vacíos, Browsershot autodetecta.
# En producción Linux: rutas absolutas a chromium-browser y node.
BROWSERSHOT_CHROME_PATH=
BROWSERSHOT_NODE_PATH=
BROWSERSHOT_NO_SANDBOX=false

# ─────────────────────────────────────────────────────────────────
# SUPER-ADMIN INICIAL — consumido por AdminUserSeeder
# ─────────────────────────────────────────────────────────────────
# Credenciales por defecto en DESARROLLO LOCAL: admin@gmail.com / 12345678
# (memorables al clonar la plantilla en proyectos nuevos).
#
# OBLIGATORIO cambiar ADMIN_PASSWORD antes de deployar a producción.
# Si ADMIN_PASSWORD está vacío en producción, el seeder FALLA.
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=12345678
ADMIN_NAME="Administrador"

# ─────────────────────────────────────────────────────────────────
# DOCKER COMPOSE — variables consumidas por docker-compose.yml
# ─────────────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME="${APP_SLUG}"
COMPOSE_POSTGRES_PORT=5432
COMPOSE_REDIS_PORT=6379
COMPOSE_POSTGRES_PASSWORD=

# ─────────────────────────────────────────────────────────────────
# VITE
# ─────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
